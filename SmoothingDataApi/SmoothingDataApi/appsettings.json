{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:3000" ]
  },
  "Binance": {
    "MaxTrackedSymbols": 50,
    "ReconnectIntervalSeconds": 5,
    "SubscribeRetries": 2,
    "SubscribeRetryDelayMs": 700
  },
  "Broadcast": {
    "IntervalMs": 500,
    "DuplicateAbsEpsilon": 0.01,
    "DuplicateRelEpsilon": 0.0000001
  }
}
